<style>
	@keyframes float {
		0%, 100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-20px);
		}
	}

	@keyframes pulse {
		0%, 100% {
			opacity: 1;
		}
		50% {
			opacity: 0.6;
		}
	}

	.navbar {
		transition: all 0.3s ease;
	}

	.navbar.scrolled {
		background: rgba(10, 10, 10, 1) !important;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.7);
	}

	html {
		scroll-behavior: smooth;
	}

	.card:hover {
		transform: translateY(-4px);
		border-color: var(--accent-primary) !important;
	}

	@media (max-width: 992px) {
		section {
			padding: 3rem 0 !important;
		}

		.col-lg-4 .card {
			transform: scale(1) !important;
		}
	}
</style>

<script>
	import { isAuthenticated, getUser } from '../utils/api.js';
	import { initToastContainer } from '../utils/toast.js';

	// Inicializar toasts
	initToastContainer();

	// Navbar scroll effect
	window.addEventListener('scroll', () => {
		const navbar = document.querySelector('.navbar');
		if (window.scrollY > 50) {
			navbar?.classList.add('scrolled');
		} else {
			navbar?.classList.remove('scrolled');
		}
	});

	// Verificar autenticación y actualizar navbar
	document.addEventListener('DOMContentLoaded', () => {
		const guestActions = document.getElementById('guestActions');
		const userActions = document.getElementById('userActions');
		const userNameNav = document.getElementById('userNameNav');
		const userAvatarNav = document.getElementById('userAvatarNav');

		if (isAuthenticated()) {
			const user = getUser();
			
			if (user && guestActions && userActions && userNameNav && userAvatarNav) {
				guestActions.classList.add('d-none');
				userActions.classList.remove('d-none');
				
				const fullName = `${user.firstName} ${user.lastName}`;
				userNameNav.textContent = user.firstName;
				
				if (user.imageUrl || user.image_url) {
					userAvatarNav.src = user.imageUrl || user.image_url;
				} else {
					userAvatarNav.src = `https://ui-avatars.com/api/?name=${encodeURIComponent(fullName)}&background=ff6b35&color=fff&size=128&bold=true`;
				}
			}
		}
	});
</script>
