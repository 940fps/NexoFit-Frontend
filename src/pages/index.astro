---
import Layout from '../layouts/Layout.astro';
import { Dumbbell, Users, Calendar, Trophy, MapPin, Mail, Phone, Clock, Star, Zap, Award, Target } from '@lucide/astro';
---

<Layout>
	<!-- Navbar Moderno -->
	<nav class="navbar navbar-expand-lg navbar-dark fixed-top" style="background: rgba(10, 10, 10, 0.95); backdrop-filter: blur(20px); border-bottom: 1px solid

 rgba(255, 107, 53, 0.2); box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);">
		<div class="container">
			<a class="navbar-brand d-flex align-items-center gap-2" href="#">
				<img src="/logo-192x192.png" alt="NexoFit Logo" height="45" style="filter: drop-shadow(0 0 8px rgba(255, 107, 53, 0.5));">
				<div>
					<div class="fw-bold fs-4 text-accent" style="line-height: 1.2;">NexoFit</div>
					<div style="font-size: 0.65rem; color: var(--text-muted); font-weight: 500;">FITNESS & WELLNESS</div>
				</div>
			</a>
			<button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
				<span class="navbar-toggler-icon"></span>
			</button>
			<div class="collapse navbar-collapse" id="navbarNav">
				<ul class="navbar-nav mx-auto gap-1">
					<li class="nav-item"><a class="nav-link" href="#inicio">Inicio</a></li>
					<li class="nav-item"><a class="nav-link" href="#servicios">Servicios</a></li>
					<li class="nav-item"><a class="nav-link" href="#clases">Clases</a></li>
					<li class="nav-item"><a class="nav-link" href="#membresias">Planes</a></li>
					<li class="nav-item"><a class="nav-link" href="#contacto">Contacto</a></li>
				</ul>
				<div class="d-flex gap-2 align-items-center" id="navActions">
					<!-- Guest Actions -->
					<div id="guestActions" class="d-flex gap-2">
						<a href="/login" class="btn btn-sm btn-outline-primary">Iniciar Sesión</a>
						<a href="/signup" class="btn btn-sm btn-primary">Únete Ahora</a>
					</div>
					
					<!-- User Actions -->
					<div id="userActions" class="d-none d-flex align-items-center gap-2">
						<a href="/dashboard" class="btn btn-sm btn-primary">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/></svg>
							Dashboard
						</a>
						<div class="d-flex align-items-center gap-2 px-2 py-1" style="background: rgba(255, 107, 53, 0.15); border-radius: 8px; border: 1px solid rgba(255, 107, 53, 0.3);">
							<img id="userAvatarNav" src="" alt="Avatar" style="width: 30px; height: 30px; border-radius: 50%; border: 2px solid var(--accent-secondary);">
							<span id="userNameNav" style="color: var(--text-primary); font-weight: 600; font-size: 0.875rem;"></span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</nav>

	<!-- Hero Section Mejorado -->
	<section id="inicio" style="background: linear-gradient(135deg, rgba(10, 10, 10, 0.97) 0%, rgba(20, 20, 20, 0.95) 100%), url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1920&q=80') center/cover; min-height: 100vh; display: flex; align-items: center; padding-top: 80px; position: relative; overflow: hidden;">
		<!-- Efectos de fondo -->
		<div style="position: absolute; top: 20%; right: 10%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(255, 107, 53, 0.15) 0%, transparent 70%); filter: blur(80px); pointer-events: none; animation: pulse 3s infinite;"></div>
		<div style="position: absolute; bottom: 10%; left: 15%; width: 350px; height: 350px; background: radial-gradient(circle, rgba(255, 165, 0, 0.12) 0%, transparent 70%); filter: blur(80px); pointer-events: none; animation: pulse 4s infinite;"></div>
		
		<div class="container">
			<div class="row align-items-center">
				<div class="col-lg-6 mb-5 mb-lg-0">
					<div class="fade-in">
						<div class="badge mb-3" style="background: rgba(255, 165, 0, 0.15); color: var(--accent-secondary); border: 1px solid rgba(255, 165, 0, 0.3); padding: 0.5rem 1rem; font-size: 0.85rem;">
							<Zap size={16} style="display: inline-block; vertical-align: middle;" class="me-1" />
							EL MEJOR GIMNASIO DE LA CIUDAD
						</div>
						<h1 class="display-2 fw-black mb-4" style="line-height: 1.1; letter-spacing: -0.02em;">
							Transforma Tu 
							<span class="d-block text-accent">Vida Hoy</span>
						</h1>
						<p class="lead mb-4" style="color: var(--text-secondary); max-width: 550px; font-size: 1.15rem;">
							Únete a NexoFit y descubre el gimnasio perfecto para alcanzar tus metas. Entrenamiento de élite, equipamiento premium y una comunidad que te impulsa.
						</p>
						<div class="d-flex gap-3 flex-wrap mb-4">
							<a href="/signup" class="btn btn-primary btn-lg" style="box-shadow: 0 4px 20px rgba(255, 107, 53, 0.4);">
								Empieza Gratis
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline-block; vertical-align: middle;" class="ms-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
							</a>
							<a href="#servicios" class="btn btn-outline-primary btn-lg">
								Ver Servicios
							</a>
						</div>
						<!-- Stats -->
						<div class="row g-4 mt-2">
							<div class="col-4">
								<div class="text-center">
									<h3 class="fw-bold mb-0 text-accent">500+</h3>
									<small style="color: var(--text-muted);">Miembros Activos</small>
								</div>
							</div>
							<div class="col-4">
								<div class="text-center">
									<h3 class="fw-bold mb-0 text-accent">50+</h3>
									<small style="color: var(--text-muted);">Clases Semanales</small>
								</div>
							</div>
							<div class="col-4">
								<div class="text-center">
									<h3 class="fw-bold mb-0 text-accent">24/7</h3>
									<small style="color: var(--text-muted);">Acceso Total</small>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="col-lg-6">
					<div class="position-relative slide-in-up">
						<img src="/logo-512x512.png" alt="NexoFit" class="img-fluid" style="max-width: 500px; margin: 0 auto; display: block; filter: drop-shadow(0 20px 60px rgba(255, 107, 53, 0.4));">
						<!-- Floating badges -->
						<div class="position-absolute" style="top: 10%; left: -5%; animation: float 3s ease-in-out infinite;">
							<div class="badge bg-success d-flex align-items-center gap-2 p-3" style="border-radius: 12px; box-shadow: 0 8px 20px rgba(16, 185, 129, 0.3);">
								<Star size={20} />
								<span>Calificación 4.9/5</span>
							</div>
						</div>
						<div class="position-absolute" style="bottom: 15%; right: -5%; animation: float 3s ease-in-out infinite; animation-delay: 1s;">
							<div class="badge d-flex align-items-center gap-2 p-3" style="background: var(--accent-gradient); border-radius: 12px; box-shadow: 0 8px 20px rgba(255, 107, 53, 0.4);">
								<Award size={20} />
								<span>Premiado 2026</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Features Strip -->
	<section style="background: var(--bg-secondary); padding: 2rem 0; border-bottom: 1px solid var(--border-color);">
		<div class="container">
			<div class="row g-4 text-center">
				<div class="col-6 col-md-3">
					<div class="d-flex align-items-center justify-content-center gap-2">
						<Clock size={24} style="color: var(--accent-primary);" />
						<div class="text-start">
							<div class="fw-bold" style="font-size: 0.95rem;">Abierto 24/7</div>
							<small style="color: var(--text-muted); font-size: 0.8rem;">Sin restricciones</small>
						</div>
					</div>
				</div>
				<div class="col-6 col-md-3">
					<div class="d-flex align-items-center justify-content-center gap-2">
						<Users size={24} style="color: var(--accent-secondary);" />
						<div class="text-start">
							<div class="fw-bold" style="font-size: 0.95rem;">Entrenadores</div>
							<small style="color: var(--text-muted); font-size: 0.8rem;">Certificados</small>
						</div>
					</div>
				</div>
				<div class="col-6 col-md-3">
					<div class="d-flex align-items-center justify-content-center gap-2">
						<Dumbbell size={24} style="color: var(--accent-primary);" />
						<div class="text-start">
							<div class="fw-bold" style="font-size: 0.95rem;">Equipo Premium</div>
							<small style="color: var(--text-muted); font-size: 0.8rem;">Última tecnología</small>
						</div>
					</div>
				</div>
				<div class="col-6 col-md-3">
					<div class="d-flex align-items-center justify-content-center gap-2">
						<Trophy size={24} style="color: var(--accent-secondary);" />
						<div class="text-start">
							<div class="fw-bold" style="font-size: 0.95rem;">Resultados</div>
							<small style="color: var(--text-muted); font-size: 0.8rem;">Garantizados</small>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Servicios Section Compacto -->
	<section id="servicios" class="py-5">
		<div class="container">
			<div class="text-center mb-5">
				<div class="badge mb-2" style="background: rgba(255, 107, 53, 0.1); color: var(--accent-primary); border: 1px solid rgba(255, 107, 53, 0.2); padding: 0.4rem 1rem;">
					NUESTROS SERVICIOS
				</div>
				<h2 class="display-5 fw-bold mb-2">Todo Lo Que <span class="text-accent">Necesitas</span></h2>
				<p class="text-muted" style="max-width: 600px; margin: 0 auto;">Instalaciones de primera clase con todo el equipo y servicios para tu transformación</p>
			</div>
			<div class="row g-3">
				<div class="col-md-6 col-lg-3">
					<div class="card h-100 border-0" style="background: var(--bg-card); transition: var(--transition);">
						<div class="card-body p-4 text-center">
							<div class="mb-3 d-inline-flex p-3" style="background: linear-gradient(135deg, rgba(255, 107, 53, 0.15), rgba(255, 165, 0, 0.1)); border-radius: 16px;">
								<Dumbbell size={32} style="color: var(--accent-primary);" />
							</div>
							<h5 class="fw-bold mb-2">Zona de Pesas</h5>
							<p class="text-muted mb-0" style="font-size: 0.9rem;">Equipamiento profesional para fuerza y masa muscular</p>
						</div>
					</div>
				</div>
				<div class="col-md-6 col-lg-3">
					<div class="card h-100 border-0" style="background: var(--bg-card); transition: var(--transition);">
						<div class="card-body p-4 text-center">
							<div class="mb-3 d-inline-flex p-3" style="background: linear-gradient(135deg, rgba(255, 165, 0, 0.15), rgba(255, 107, 53, 0.1)); border-radius: 16px;">
								<Users size={32} style="color: var(--accent-secondary);" />
							</div>
							<h5 class="fw-bold mb-2">Clases Grupales</h5>
							<p class="text-muted mb-0" style="font-size: 0.9rem;">Yoga, spinning, crossfit y más con instructores expertos</p>
						</div>
					</div>
				</div>
				<div class="col-md-6 col-lg-3">
					<div class="card h-100 border-0" style="background: var(--bg-card); transition: var(--transition);">
						<div class="card-body p-4 text-center">
							<div class="mb-3 d-inline-flex p-3" style="background: linear-gradient(135deg, rgba(255, 107, 53, 0.15), rgba(255, 165, 0, 0.1)); border-radius: 16px;">
								<Target size={32} style="color: var(--accent-primary);" />
							</div>
							<h5 class="fw-bold mb-2">Entrenamiento Personal</h5>
							<p class="text-muted mb-0" style="font-size: 0.9rem;">Planes personalizados con entrenadores certificados</p>
						</div>
					</div>
				</div>
				<div class="col-md-6 col-lg-3">
					<div class="card h-100 border-0" style="background: var(--bg-card); transition: var(--transition);">
						<div class="card-body p-4 text-center">
							<div class="mb-3 d-inline-flex p-3" style="background: linear-gradient(135deg, rgba(255, 165, 0, 0.15), rgba(255, 107, 53, 0.1)); border-radius: 16px;">
								<Calendar size={32} style="color: var(--accent-secondary);" />
							</div>
							<h5 class="fw-bold mb-2">Horario Flexible</h5>
							<p class="text-muted mb-0" style="font-size: 0.9rem;">Acceso 24/7 que se adapta a tu estilo de vida</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Clases Section Moderno -->
	<section id="clases" style="background: var(--bg-secondary);" class="py-5">
		<div class="container">
			<div class="text-center mb-5">
				<div class="badge mb-2" style="background: rgba(255, 165, 0, 0.1); color: var(--accent-secondary); border: 1px solid rgba(255, 165, 0, 0.2); padding: 0.4rem 1rem;">
					CLASES POPULARES
				</div>
				<h2 class="display-5 fw-bold mb-2">Encuentra Tu <span class="text-accent">Clase Ideal</span></h2>
				<p class="text-muted" style="max-width: 600px; margin: 0 auto;">Variedad de entrenamientos guiados para todos los niveles</p>
			</div>
			<div class="row g-3">
				<div class="col-md-6 col-lg-4">
					<div class="class-card" style="background: linear-gradient(rgba(10, 10, 10, 0.7), rgba(10, 10, 10, 0.9)), url('https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=800&q=80') center/cover; border-radius: 16px; padding: 2rem; min-height: 220px; display: flex; flex-direction: column; justify-content: flex-end; border: 1px solid var(--border-color); cursor: pointer;">
						<span class="badge mb-2 align-self-start" style="background: var(--accent-gradient);">Yoga & Pilates</span>
						<h5 class="fw-bold mb-2">Equilibrio y Flexibilidad</h5>
						<p class="mb-0 text-muted" style="font-size: 0.9rem;">Mejora tu postura y reduce el estrés</p>
					</div>
				</div>
				<div class="col-md-6 col-lg-4">
					<div class="class-card" style="background: linear-gradient(rgba(10, 10, 10, 0.7), rgba(10, 10, 10, 0.9)), url('https://images.unsplash.com/photo-1571902943202-507ec2618e8f?w=800&q=80') center/cover; border-radius: 16px; padding: 2rem; min-height: 220px; display: flex; flex-direction: column; justify-content: flex-end; border: 1px solid var(--border-color); cursor: pointer;">
						<span class="badge mb-2 align-self-start" style="background: var(--accent-gradient);">Spinning</span>
						<h5 class="fw-bold mb-2">Cardio Intenso</h5>
						<p class="mb-0 text-muted" style="font-size: 0.9rem;">Quema calorías con música energizante</p>
					</div>
				</div>
				<div class="col-md-6 col-lg-4">
					<div class="class-card" style="background: linear-gradient(rgba(10, 10, 10, 0.7), rgba(10, 10, 10, 0.9)), url('https://images.unsplash.com/photo-1599058917212-d750089bc07e?w=800&q=80') center/cover; border-radius: 16px; padding: 2rem; min-height: 220px; display: flex; flex-direction: column; justify-content: flex-end; border: 1px solid var(--border-color); cursor: pointer;">
						<span class="badge mb-2 align-self-start" style="background: var(--accent-gradient);">CrossFit</span>
						<h5 class="fw-bold mb-2">Alta Intensidad</h5>
						<p class="mb-0 text-muted" style="font-size: 0.9rem;">Fuerza, resistencia y agilidad combinadas</p>
					</div>
				</div>
				<div class="col-md-6 col-lg-4">
					<div class="class-card" style="background: linear-gradient(rgba(10, 10, 10, 0.7), rgba(10, 10, 10, 0.9)), url('https://images.unsplash.com/photo-1518611012118-696072aa579a?w=800&q=80') center/cover; border-radius: 16px; padding: 2rem; min-height: 220px; display: flex; flex-direction: column; justify-content: flex-end; border: 1px solid var(--border-color); cursor: pointer;">
						<span class="badge mb-2 align-self-start" style="background: var(--accent-gradient);">Zumba</span>
						<h5 class="fw-bold mb-2">Baile y Fitness</h5>
						<p class="mb-0 text-muted" style="font-size: 0.9rem;">Diversión con ritmos latinos</p>
					</div>
				</div>
				<div class="col-md-6 col-lg-4">
					<div class="class-card" style="background: linear-gradient(rgba(10, 10, 10, 0.7), rgba(10, 10, 10, 0.9)), url('https://images.unsplash.com/photo-1549576490-b0b4831ef60a?w=800&q=80') center/cover; border-radius: 16px; padding: 2rem; min-height: 220px; display: flex; flex-direction: column; justify-content: flex-end; border: 1px solid var(--border-color); cursor: pointer;">
						<span class="badge mb-2 align-self-start" style="background: var(--accent-gradient);">Boxing</span>
						<h5 class="fw-bold mb-2">Técnica y Potencia</h5>
						<p class="mb-0 text-muted" style="font-size: 0.9rem;">Mejora coordinación y libera tensión</p>
					</div>
				</div>
				<div class="col-md-6 col-lg-4">
					<div class="class-card" style="background: linear-gradient(rgba(10, 10, 10, 0.7), rgba(10, 10, 10, 0.9)), url('https://images.unsplash.com/photo-1540206395-68808572332f?w=800&q=80') center/cover; border-radius: 16px; padding: 2rem; min-height: 220px; display: flex; flex-direction: column; justify-content: flex-end; border: 1px solid var(--border-color); cursor: pointer;">
						<span class="badge mb-2 align-self-start" style="background: var(--accent-gradient);">Funcional</span>
						<h5 class="fw-bold mb-2">Movimiento Natural</h5>
						<p class="mb-0 text-muted" style="font-size: 0.9rem;">Fortalece todo el cuerpo</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Membresías Section Moderno -->
	<section id="membresias" class="py-5">
		<div class="container">
			<div class="text-center mb-5">
				<div class="badge mb-2" style="background: rgba(255, 107, 53, 0.1); color: var(--accent-primary); border: 1px solid rgba(255, 107, 53, 0.2); padding: 0.4rem 1rem;">
					PLANES Y PRECIOS
				</div>
				<h2 class="display-5 fw-bold mb-2">Elige Tu <span class="text-accent">Membresía</span></h2>
				<p class="text-muted" style="max-width: 600px; margin: 0 auto;">Planes flexibles sin permanencia que se ajustan a tus necesidades</p>
			</div>
			<div class="row g-4">
				<!-- Plan Básico -->
				<div class="col-lg-4">
					<div class="card h-100 border-0" style="background: var(--bg-card);">
						<div class="card-body p-4">
							<h4 class="fw-bold mb-1">Básico</h4>
							<p class="text-muted mb-4" style="font-size: 0.9rem;">Perfecto para comenzar</p>
							<div class="mb-4">
								<span class="display-4 fw-bold text-accent">$29</span>
								<span class="text-muted">/mes</span>
							</div>
							<ul class="list-unstyled mb-4" style="line-height: 2;">
								<li class="mb-2">✓ Acceso a zona de pesas</li>
								<li class="mb-2">✓ Zona cardiovascular</li>
								<li class="mb-2">✓ Vestidores y duchas</li>
								<li class="mb-2 text-muted">✗ Clases grupales</li>
								<li class="mb-2 text-muted">✗ Entrenador personal</li>
							</ul>
							<a href="/signup" class="btn btn-outline-primary w-100">Seleccionar Plan</a>
						</div>
					</div>
				</div>
				
				<!-- Plan Premium -->
				<div class="col-lg-4">
					<div class="card h-100 border-0" style="background: var(--bg-card); border: 2px solid var(--accent-primary) !important; position: relative; transform: scale(1.05); box-shadow: 0 8px 30px rgba(255, 107, 53, 0.3);">
						<div class="position-absolute top-0 start-50 translate-middle">
							<span class="badge" style="background: var(--accent-gradient); padding: 0.5rem 1.5rem; font-size: 0.75rem; letter-spacing: 0.05em;">MÁS POPULAR</span>
						</div>
						<div class="card-body p-4" style="padding-top: 2rem !important;">
							<h4 class="fw-bold mb-1">Premium</h4>
							<p class="text-muted mb-4" style="font-size: 0.9rem;">Mejor relación calidad-precio</p>
							<div class="mb-4">
								<span class="display-4 fw-bold text-accent">$49</span>
								<span class="text-muted">/mes</span>
							</div>
							<ul class="list-unstyled mb-4" style="line-height: 2;">
								<li class="mb-2">✓ Todo del plan Básico</li>
								<li class="mb-2">✓ Clases grupales ilimitadas</li>
								<li class="mb-2">✓ Nutrición básica</li>
								<li class="mb-2">✓ Acceso prioritario</li>
								<li class="mb-2 text-muted">✗ Entrenador personal</li>
							</ul>
							<a href="/signup" class="btn btn-primary w-100">Seleccionar Plan</a>
						</div>
					</div>
				</div>
				
				<!-- Plan Elite -->
				<div class="col-lg-4">
					<div class="card h-100 border-0" style="background: var(--bg-card);">
						<div class="card-body p-4">
							<h4 class="fw-bold mb-1">Elite</h4>
							<p class="text-muted mb-4" style="font-size: 0.9rem;">Experiencia completa</p>
							<div class="mb-4">
								<span class="display-4 fw-bold text-accent">$79</span>
								<span class="text-muted">/mes</span>
							</div>
							<ul class="list-unstyled mb-4" style="line-height: 2;">
								<li class="mb-2">✓ Todo del plan Premium</li>
