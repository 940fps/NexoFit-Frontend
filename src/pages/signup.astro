---
import Layout from '../layouts/Layout.astro';
import { UserPlus, Mail, Lock, User, Phone } from '@lucide/astro';
---

<Layout>
  <div class="signup-page">
    <div class="signup-container">
      <!-- Logo y título -->
      <div class="signup-header">
        <div class="logo-icon">
          <UserPlus size={40} />
        </div>
        <h1>Únete a NexoFit</h1>
        <p>Crea tu cuenta y comienza tu viaje</p>
      </div>

      <!-- Formulario -->
      <form id="signupForm" class="signup-form">
        <div class="form-row">
          <div class="form-group">
            <div class="input-icon">
              <User size={18} />
            </div>
            <input 
              type="text" 
              id="firstName" 
              name="firstName"
              placeholder="Nombre" 
              required
            />
          </div>

          <div class="form-group">
            <div class="input-icon">
              <User size={18} />
            </div>
            <input 
              type="text" 
              id="lastName" 
              name="lastName"
              placeholder="Apellido" 
              required
            />
          </div>
        </div>

        <div class="form-group">
          <div class="input-icon">
            <Mail size={20} />
          </div>
          <input 
            type="email" 
            id="email" 
            name="email"
            placeholder="Correo electrónico" 
            required
            autocomplete="email"
          />
        </div>

        <div class="form-group">
          <div class="input-icon">
            <Phone size={20} />
          </div>
          <input 
            type="tel" 
            id="phone" 
            name="phone"
            placeholder="Teléfono (opcional)"
            autocomplete="tel"
          />
        </div>

        <div class="form-row">
          <div class="form-group">
            <div class="input-icon">
              <Lock size={18} />
            </div>
            <input 
              type="password" 
              id="password" 
              name="password"
              placeholder="Contraseña" 
              required
              minlength="6"
              autocomplete="new-password"
            />
          </div>

          <div class="form-group">
            <div class="input-icon">
              <Lock size={18} />
            </div>
            <input 
              type="password" 
              id="confirmPassword" 
              name="confirmPassword"
              placeholder="Confirmar" 
              required
              minlength="6"
              autocomplete="new-password"
            />
          </div>
        </div>

        <button type="submit" class="btn-submit">
          Crear Cuenta
        </button>

        <div class="form-footer">
          <span>¿Ya tienes cuenta?</span>
          <a href="/login">Inicia sesión</a>
        </div>

        <a href="/" class="btn-back">← Volver al inicio</a>
      </form>
    </div>
  </div>
</Layout>

<style>
  .signup-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 50%, #0a0a0a 100%);
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .signup-page::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(255, 165, 0, 0.1) 0%, transparent 70%);
    animation: pulse 4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.1); opacity: 0.8; }
  }

  .signup-container {
    width: 100%;
    max-width: 520px;
    background: rgba(20, 20, 20, 0.95);
    backdrop-filter: blur(20px);
    border-radius: 24px;
    padding: 2.5rem 2rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 
                0 0 0 1px rgba(255, 165, 0, 0.2);
    position: relative;
    z-index: 1;
  }

  .signup-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .logo-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, var(--accent-secondary), var(--accent-primary));
    border-radius: 16px;
    margin-bottom: 1rem;
    box-shadow: 0 8px 20px rgba(255, 165, 0, 0.4);
  }

  .logo-icon :global(svg) {
    color: white;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
  }

  .signup-header h1 {
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-secondary), var(--accent-primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .signup-header p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin: 0;
  }

  .signup-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    position: relative;
  }

  .input-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent-secondary);
    display: flex;
    align-items: center;
    z-index: 1;
  }

  .form-group input {
    width: 100%;
    padding: 0.9rem 0.9rem 0.9rem 2.75rem;
    background: var(--bg-primary);
    border: 2px solid rgba(255, 165, 0, 0.2);
    border-radius: 12px;
    color: var(--text-primary);
    font-size: 0.95rem;
    transition: all 0.3s ease;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--accent-secondary);
    box-shadow: 0 0 0 3px rgba(255, 165, 0, 0.1);
  }

  .form-group input::placeholder {
    color: var(--text-muted);
  }

  .btn-submit {
    width: 100%;
    padding: 1rem;
    background: linear-gradient(135deg, var(--accent-secondary), var(--accent-primary));
    border: none;
    border-radius: 12px;
    color: white;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(255, 165, 0, 0.3);
    margin-top: 0.5rem;
  }

  .btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255, 165, 0, 0.4);
  }

  .btn-submit:active {
    transform: translateY(0);
  }

  .btn-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  .form-footer {
    text-align: center;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255, 165, 0, 0.1);
  }

  .form-footer span {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-right: 0.5rem;
  }

  .form-footer a {
    color: var(--accent-secondary);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .form-footer a:hover {
    color: var(--accent-primary);
  }

  .btn-back {
    display: block;
    text-align: center;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    margin-top: 0.5rem;
    transition: color 0.3s ease;
  }

  .btn-back:hover {
    color: var(--accent-secondary);
  }

  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .signup-container {
      padding: 2rem 1.5rem;
    }

    .signup-header h1 {
      font-size: 1.75rem;
    }
  }
</style>

<script>
  import { register, isAuthenticated } from '../utils/api.js';
  import { showSuccess, showError, showWarning, initToastContainer } from '../utils/toast.js';

  initToastContainer();

  if (isAuthenticated()) {
    window.location.href = '/dashboard';
  }

  const form = document.getElementById('signupForm') as HTMLFormElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const firstName = (document.getElementById('firstName') as HTMLInputElement)?.value.trim();
    const lastName = (document.getElementById('lastName') as HTMLInputElement)?.value.trim();
    const email = (document.getElementById('email') as HTMLInputElement)?.value.trim();
    const phone = (document.getElementById('phone') as HTMLInputElement)?.value.trim() || undefined;
    const password = (document.getElementById('password') as HTMLInputElement)?.value;
    const confirmPassword = (document.getElementById('confirmPassword') as HTMLInputElement)?.value;

    if (password !== confirmPassword) {
      showWarning('Las contraseñas no coinciden');
      return;
    }

    if (password && password.length < 6) {
      showWarning('La contraseña debe tener al menos 6 caracteres');
      return;
    }

    const formData = {
      first_name: firstName,
      last_name: lastName,
      email: email,
      phone: phone,
      password: password,
    };

    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
    
    if (!submitBtn) return;
    
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner"></span>Creando cuenta...';
    
    try {
      const response = await register(formData);
      
      if (response.success) {
        showSuccess('¡Cuenta creada! Bienvenido a NexoFit');
        setTimeout(() => {
          window.location.href = '/dashboard';
        }, 1000);
      } else {
        showError(response.message || 'Error al crear la cuenta');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Crear Cuenta';
        }
      }
    } catch (error) {
      const errorMessage = error instanceof Error ? error.message : 'Error al conectar con el servidor';
      showError(errorMessage);
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Crear Cuenta';
      }
    }
  });
</script>

<style>
  .spinner {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    margin-right: 0.5rem;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
