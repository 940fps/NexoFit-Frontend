---
import Layout from '../layouts/Layout.astro';
import { LogIn, Mail, Lock } from '@lucide/astro';
---

<Layout>
  <div class="login-page">
    <div class="login-container">
      <!-- Logo y título -->
      <div class="login-header">
        <div class="logo-icon">
          <LogIn size={40} />
        </div>
        <h1>NexoFit</h1>
        <p>Accede a tu cuenta</p>
      </div>

      <!-- Formulario -->
      <form id="loginForm" class="login-form">
        <div class="form-group">
          <div class="input-icon">
            <Mail size={20} />
          </div>
          <input 
            type="email" 
            id="email" 
            name="email"
            placeholder="Correo electrónico" 
            required
            autocomplete="email"
          />
        </div>

        <div class="form-group">
          <div class="input-icon">
            <Lock size={20} />
          </div>
          <input 
            type="password" 
            id="password" 
            name="password"
            placeholder="Contraseña" 
            required
            autocomplete="current-password"
          />
        </div>

        <button type="submit" class="btn-submit">
          Iniciar Sesión
        </button>

        <div class="form-footer">
          <span>¿No tienes cuenta?</span>
          <a href="/signup">Regístrate aquí</a>
        </div>

        <a href="/" class="btn-back">← Volver al inicio</a>
      </form>
    </div>
  </div>
</Layout>

<style>
  .login-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 50%, #0a0a0a 100%);
    padding: 1rem;
    position: relative;
    overflow: hidden;
  }

  .login-page::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(255, 107, 53, 0.1) 0%, transparent 70%);
    animation: pulse 4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.1); opacity: 0.8; }
  }

  .login-container {
    width: 100%;
    max-width: 420px;
    background: rgba(20, 20, 20, 0.95);
    backdrop-filter: blur(20px);
    border-radius: 24px;
    padding: 2.5rem 2rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 
                0 0 0 1px rgba(255, 107, 53, 0.2);
    position: relative;
    z-index: 1;
  }

  .login-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .logo-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    border-radius: 16px;
    margin-bottom: 1rem;
    box-shadow: 0 8px 20px rgba(255, 107, 53, 0.4);
  }

  .logo-icon :global(svg) {
    color: white;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
  }

  .login-header h1 {
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .login-header p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin: 0;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    position: relative;
  }

  .input-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent-primary);
    display: flex;
    align-items: center;
    z-index: 1;
  }

  .form-group input {
    width: 100%;
    padding: 1rem 1rem 1rem 3rem;
    background: var(--bg-primary);
    border: 2px solid rgba(255, 107, 53, 0.2);
    border-radius: 12px;
    color: var(--text-primary);
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 3px rgba(255, 107, 53, 0.1);
  }

  .form-group input::placeholder {
    color: var(--text-muted);
  }

  .btn-submit {
    width: 100%;
    padding: 1rem;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    border: none;
    border-radius: 12px;
    color: white;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(255, 107, 53, 0.3);
    margin-top: 0.5rem;
  }

  .btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
  }

  .btn-submit:active {
    transform: translateY(0);
  }

  .btn-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  .form-footer {
    text-align: center;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255, 107, 53, 0.1);
  }

  .form-footer span {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-right: 0.5rem;
  }

  .form-footer a {
    color: var(--accent-primary);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .form-footer a:hover {
    color: var(--accent-secondary);
  }

  .btn-back {
    display: block;
    text-align: center;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    margin-top: 0.5rem;
    transition: color 0.3s ease;
  }

  .btn-back:hover {
    color: var(--accent-secondary);
  }

  @media (max-width: 480px) {
    .login-container {
      padding: 2rem 1.5rem;
    }

    .login-header h1 {
      font-size: 1.75rem;
    }
  }
</style>

<script>
  import { login, isAuthenticated } from '../utils/api.js';
  import { showSuccess, showError, initToastContainer } from '../utils/toast.js';

  initToastContainer();

  if (isAuthenticated()) {
    window.location.href = '/dashboard';
  }

  const form = document.getElementById('loginForm') as HTMLFormElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const email = (document.getElementById('email') as HTMLInputElement)?.value;
    const password = (document.getElementById('password') as HTMLInputElement)?.value;
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
    
    if (!submitBtn || !email || !password) return;
    
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner"></span>Iniciando sesión...';
    
    try {
      const response = await login(email, password);
      
      if (response.success) {
        showSuccess('¡Bienvenido! Redirigiendo...');
        setTimeout(() => {
          window.location.href = '/dashboard';
        }, 800);
      } else {
        showError(response.message || 'Error al iniciar sesión');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Iniciar Sesión';
        }
      }
    } catch (error) {
      const errorMessage = error instanceof Error ? error.message : 'Error al conectar con el servidor';
      showError(errorMessage);
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Iniciar Sesión';
      }
    }
  });
</script>

<style>
  .spinner {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    margin-right: 0.5rem;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
